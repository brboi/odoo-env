{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python3",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "search.useIgnoreFiles": false,
  "search.exclude": {
    ".cache/**": true,
    ".venv/**": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "src/**": true
  }
}
