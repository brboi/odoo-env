# odoo-env.toml — copy to odoo-env.toml and customize (this file is gitignored)
#
#   cp odoo-env.toml.example odoo-env.toml
#
# [_.odoorc]        global Odoo conf defaults applied to all environments
# [_.branches]      global branch defaults merged into every environment
# [_.repos]         global custom repo URLs (alias → git URL)
# [env.branches]    repo → branch mapping (community is required; env-specific wins over defaults)
# [env.odoorc]      per-env Odoo conf overrides — optional
# [env.repos]       custom repo URLs for non-odoo repos (alias → git URL)

[_.odoorc]
admin_password = "Password"
db_host = "postgres"
db_port = 5432
db_user = "odoo"
db_password = "odoo"
db_template = "template0"
smtp_server = "mailpit"
smtp_port = 1025

[my-main.branches]
community = "master"
enterprise = "master-fix"

[my-main.odoorc]
port = 8070

[my-other.branches]
community = "18.0"
enterprise = "18.0-fix"

[my-other.odoorc]
port = 8069
db_name = "mydb"

# Custom (non-odoo) repos: declare URL here, reference branch in [env.branches]
# [my-client.branches]
# community = "17.0"
# enterprise = "17.0"
# my-addons = "main"
#
# [my-client.repos]
# my-addons = "git@github.com:myclient/odoo-addons.git"

# Global custom repos available in all environments:
# [_.repos]
# utils = "git@github.com:mycompany/odoo-utils.git"
# [_.branches]
# utils = "main"
