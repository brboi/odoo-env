# odoo-env.toml — copy to odoo-env.toml and customize (this file is gitignored)
#
#   cp odoo-env.toml.example odoo-env.toml
#
# [odoorc]          global Odoo conf defaults
# [options]         global options (skip_js_tooling, etc.)
# [remote.X]        custom repo URLs: [remote.my-addons] origin = "git@..."
# [[profile]]       one section per environment
#   name = "..."
#   branch.community = "..."   repo → branch (community required)
#   branch.enterprise = "..."
#   odoorc.port = 8070         per-profile Odoo conf overrides (dotted keys)
#   options.skip_js_tooling = ["repo"]

[odoorc]
port = 8069
admin_passwd = "Password"
server_wide_modules = "base,web"
db_host = "postgres"
db_port = 5432
db_user = "odoo"
db_password = "odoo"
db_template = "template0"
smtp_server = "mailpit"
smtp_port = 1025

[[profile]]
name = "master"
branch.community = "master"
branch.enterprise = "master"

[[profile]]
name = "my-main"
branch.community = "master"
branch.enterprise = "master-fix"
odoorc.port = 8070

[[profile]]
name = "my-other"
branch.community = "18.0"
branch.enterprise = "18.0-fix"

# Custom db_name:
# odoorc.db_name = "mydb"

# Custom (non-odoo) repos:
# [remote.my-addons]
# origin = "git@github.com:myclient/odoo-addons.git"
#
# [[profile]]
# name = "my-client"
# branch.community = "17.0"
# branch.enterprise = "17.0"
# branch.my-addons = "main"

# Skip JS tooling per-profile or globally:
# options.skip_js_tooling = ["my-addons"]
#
# [options]
# skip_js_tooling = ["my-addons"]

# PR branch formats:
# branch.enterprise = "pr/1261"
# branch.enterprise = "odoo-dev/enterprise#1261"
# branch.enterprise = "https://github.com/odoo-dev/enterprise/pull/1261"
