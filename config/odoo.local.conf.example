; Local overrides — copy this file to odoo.local.conf (gitignored)
; Settings here are merged on top of odoo.conf by odoo-env at startup.
[options]
; db_host = myserver
; db_port = 5432
; db_user = myuser
; db_password = mypassword
; db_name = mydb
; workers = 2
; limit_time_cpu = 600
; limit_time_real = 1200
