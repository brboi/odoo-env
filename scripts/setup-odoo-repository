#!/usr/bin/env python3
"""setup-odoo-repository: Initialize a bare Odoo repository.

Usage:
    setup-odoo-repository <repo>

Arguments:
    repo    GitHub repository name under github.com/odoo/ (e.g. odoo, enterprise)
            Special case: 'odoo' is stored locally as 'community'

Examples:
    setup-odoo-repository odoo
    setup-odoo-repository enterprise
    setup-odoo-repository upgrade-util
"""

import argparse
import subprocess
import sys
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parent.parent
CACHE_DIR = ROOT_DIR / ".cache" / "git"

# Only hardcoded alias: github.com/odoo/odoo is called 'community' locally
ALIAS = {"odoo": "community"}


def git(bare_path: Path, *args: str, check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", f"--git-dir={bare_path}", *args],
        check=check,
    )


def dev_remote_exists(repo: str) -> bool:
    result = subprocess.run(
        ["git", "ls-remote", f"git@github.com:odoo-dev/{repo}.git"],
        capture_output=True,
        check=False,
    )
    return result.returncode == 0


def setup_repo(repo: str) -> None:
    alias = ALIAS.get(repo, repo)
    repo_url = f"git@github.com:odoo/{repo}.git"
    bare_path = CACHE_DIR / f"{alias}.git"

    CACHE_DIR.mkdir(parents=True, exist_ok=True)

    if bare_path.is_dir():
        print(f"Repository already exists: {bare_path}")
        git(bare_path, "remote", "set-url", "origin", repo_url)
    else:
        print(f"Cloning bare repository: {repo_url} -> {bare_path}")
        subprocess.run(["git", "clone", "--bare", repo_url, str(bare_path)], check=True)

    print("Configuring refspecs...")
    git(bare_path, "config", "--replace-all", "remote.origin.fetch", "+refs/heads/*:refs/remotes/origin/*")
    git(bare_path, "config", "--add", "remote.origin.fetch", "+refs/pull/*/head:refs/remotes/origin/pr/*")

    print("Checking for dev remote (github.com/odoo-dev)...")
    if dev_remote_exists(repo):
        dev_url = f"git@github.com:odoo-dev/{repo}.git"
        print(f"Dev remote found: {dev_url}")
        existing_remotes = subprocess.run(
            ["git", f"--git-dir={bare_path}", "remote"],
            capture_output=True, text=True, check=True,
        ).stdout.split()
        if "dev" in existing_remotes:
            git(bare_path, "remote", "set-url", "dev", dev_url)
        else:
            git(bare_path, "remote", "add", "dev", dev_url)
        git(bare_path, "config", "--replace-all", "remote.dev.fetch", "+refs/heads/*:refs/remotes/dev/*")
    else:
        print("No dev remote.")

    print(f"Done: {bare_path}")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Initialize a bare Odoo repository",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("repo", help="GitHub repo name under github.com/odoo/ (e.g. odoo, enterprise)")

    args = parser.parse_args()
    setup_repo(args.repo)


if __name__ == "__main__":
    main()
