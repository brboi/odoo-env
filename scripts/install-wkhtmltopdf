#!/usr/bin/env bash
set -e

WKHTMLTOPDF_VERSION="0.12.6.1-3"
ARCH=$(dpkg --print-architecture)  # amd64 or arm64
DISTRO=$(. /etc/os-release && echo "$VERSION_CODENAME")  # bookworm, jammy, etc.

echo "Installing wkhtmltopdf ${WKHTMLTOPDF_VERSION} for ${DISTRO} (${ARCH})..."

curl -SLo /tmp/wkhtmltox.deb \
    "https://github.com/wkhtmltopdf/packaging/releases/download/${WKHTMLTOPDF_VERSION}/wkhtmltox_${WKHTMLTOPDF_VERSION}.${DISTRO}_${ARCH}.deb"

sudo apt-get install -y /tmp/wkhtmltox.deb
rm /tmp/wkhtmltox.deb

echo "wkhtmltopdf installed successfully."
wkhtmltopdf --version
