#!/usr/bin/env python3
# PYTHON_ARGCOMPLETE_OK
"""odoo-env: Configure and launch an Odoo development environment.

Usage:
    odoo-env activate <env>   Set up worktrees and launch shell
    odoo-env <env>            Shorthand for activate
    odoo-env list             List environments from odoo-env.toml
    odoo-env status           Git status (current env, or all if none active)
    odoo-env rebase           Fetch + rebase (current env, or all if none active)
    odoo-env remove <env>     Remove worktrees for an environment

Environments are declared in odoo-env.toml at the repo root.
Copy odoo-env.toml.example to odoo-env.toml and customize.
"""

import argparse
import configparser
import json
import os
import tomllib
import re
import shutil
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

try:
    import argcomplete
except ImportError:
    argcomplete = None

ROOT_DIR = Path(__file__).resolve().parent.parent
CACHE_DIR = ROOT_DIR / ".cache" / "git"
SRC_DIR = ROOT_DIR / "src"

# Maps local alias → GitHub repo name (only non-identity mappings)
REVERSE_ALIAS = {"community": "odoo"}

# ANSI colors
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
BLUE = "\033[0;34m"
NC = "\033[0m"


def hyperlink(text: str, url: str) -> str:
    """Wrap text as an OSC 8 terminal hyperlink (ctrl-click in most modern terminals)."""
    return f"\033]8;;{url}\033\\{text}\033]8;;\033\\"


def log_info(msg: str) -> None:
    print(f"{BLUE}[INFO]{NC} {msg}", file=sys.stderr)


def log_ok(msg: str) -> None:
    print(f"{GREEN}[OK]{NC} {msg}", file=sys.stderr)


def log_warn(msg: str) -> None:
    print(f"{YELLOW}[WARN]{NC} {msg}", file=sys.stderr)


def log_error(msg: str) -> None:
    print(f"{RED}[ERROR]{NC} {msg}", file=sys.stderr)


def git(bare_path: Path, *args: str, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", f"--git-dir={bare_path}", *args],
        check=check,
        capture_output=capture,
    )


def git_wt(worktree_path: Path, *args: str, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    """Run a git command inside a (non-bare) worktree directory."""
    return subprocess.run(
        ["git", "-C", str(worktree_path), *args],
        check=check,
        capture_output=capture,
    )


def stable_base(branch: str) -> str | None:
    """Return the stable base of a feature branch, or None if already stable.

    'master-parrot' -> 'master'
    '17.0-fix'      -> '17.0'
    'master'        -> None
    '18.0'          -> None
    """
    if re.match(r'^\d+\.\d+$', branch) or branch == "master":
        return None
    if branch.startswith("master-"):
        return "master"
    m = re.match(r'^(\d+\.\d+)-', branch)
    if m:
        return m.group(1)
    return None


RUNBOT_BASE_URL = "https://runbot.odoo.com"


def deduce_runbot_bundles(repo_branches: dict[str, str], resolved_pr_branches: dict[str, str] | None = None) -> list[str]:
    """Deduce runbot bundle name(s) from a repo→branch mapping.

    Returns a list of candidate bundle names (usually one).
    - Feature branches (master-fix, 18.0-fix) → bundle name = branch name
    - PR specs → resolved to actual branch via resolved_pr_branches mapping
    - If all branches are stable (master, 18.0) → returns the stable version

    resolved_pr_branches: optional {pr_spec: resolved_branch_name} for PR branches.
    Multiple different candidates are returned as-is; caller decides how to display.
    """
    candidates: list[str] = []
    stable_version: str | None = None

    for repo, branch in repo_branches.items():
        pr_spec = parse_pr(branch)
        if pr_spec:
            resolved = (resolved_pr_branches or {}).get(branch)
            if resolved and stable_base(resolved) is not None:
                # resolved PR branch is a feature branch
                if resolved not in candidates:
                    candidates.append(resolved)
            # unresolved PR: skip (can't determine bundle name)
            continue

        base = stable_base(branch)
        if base is None:
            # This is a stable branch (master, 18.0, etc.)
            if stable_version is None:
                stable_version = branch
        else:
            # Feature branch
            if branch not in candidates:
                candidates.append(branch)

    if not candidates and stable_version:
        return [stable_version]
    return candidates


def runbot_bundle_urls(bundles: list[str]) -> list[str]:
    """Return runbot URLs for a list of bundle names."""
    return [f"{RUNBOT_BASE_URL}/runbot/bundle/{b}" for b in bundles]


def parse_pr(branch: str) -> dict | None:
    """Parse a PR branch spec into a dict, or None if not a PR spec.

    Supported formats:
      pr/1261                                    → origin PR
      odoo-dev/enterprise#1261                   → fork PR shorthand
      https://github.com/odoo-dev/enterprise/pull/1261  → fork PR full URL
    """
    # Format 1: pr/NNNN (origin PR)
    m = re.match(r'^pr/(\d+)$', branch)
    if m:
        number = m.group(1)
        return {
            "number": number,
            "remote_url": None,
            "github_org_repo": None,
            "dir_slug": f"pr-{number}",
        }

    # Format 2: org/repo#NNNN (fork PR shorthand)
    m = re.match(r'^([\w.-]+/[\w.-]+)#(\d+)$', branch)
    if m:
        org_repo = m.group(1)
        number = m.group(2)
        org = org_repo.split("/")[0]
        return {
            "number": number,
            "remote_url": f"git@github.com:{org_repo}.git",
            "github_org_repo": org_repo,
            "dir_slug": f"{org}-pr-{number}",
        }

    # Format 3: https://github.com/org/repo/pull/NNNN (full GitHub URL)
    m = re.match(r'^https://github\.com/([\w.-]+/[\w.-]+)/pull/(\d+)$', branch)
    if m:
        org_repo = m.group(1)
        number = m.group(2)
        org = org_repo.split("/")[0]
        return {
            "number": number,
            "remote_url": f"git@github.com:{org_repo}.git",
            "github_org_repo": org_repo,
            "dir_slug": f"{org}-pr-{number}",
        }

    return None


def branch_to_dir(branch: str) -> str:
    """Convert a branch name to a filesystem-safe directory name.

    For PR specs, returns the canonical dir_slug (e.g. 'pr-1261', 'odoo-dev-pr-1261').
    For regular branches, replaces '/' with '-'.
    """
    spec = parse_pr(branch)
    if spec:
        return spec["dir_slug"]
    return branch.replace("/", "-")


def remotes(bare_path: Path) -> list[str]:
    """Return remotes ordered: origin first, then others alphabetically."""
    result = git(bare_path, "remote", check=False, capture=True)
    if result.returncode != 0:
        return []
    all_remotes = result.stdout.decode().split()
    return sorted(all_remotes, key=lambda r: (0 if r == "origin" else 1, r))


def dev_remote_exists(repo: str) -> bool:
    result = subprocess.run(
        ["git", "ls-remote", f"git@github.com:odoo-dev/{repo}.git"],
        capture_output=True, check=False,
    )
    return result.returncode == 0


def setup_bare_repo(alias: str, url: str | None = None) -> None:
    if url is None:
        github_repo = REVERSE_ALIAS.get(alias, alias)
        url = f"git@github.com:odoo/{github_repo}.git"
        check_dev_remote = True
    else:
        github_repo = alias
        check_dev_remote = False

    bare_path = CACHE_DIR / f"{alias}.git"

    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    log_info(f"Cloning bare repository: {url} -> {bare_path}")
    subprocess.run(["git", "clone", "--bare", url, str(bare_path)], check=True)

    # Configure refspecs
    git(bare_path, "config", "--replace-all", "remote.origin.fetch", "+refs/heads/*:refs/remotes/origin/*")
    git(bare_path, "config", "--add", "remote.origin.fetch", "+refs/pull/*/head:refs/remotes/origin/pr/*")

    # Dev remote (only for odoo repos)
    if check_dev_remote:
        log_info(f"Checking for dev remote (github.com/odoo-dev/{github_repo})...")
        if dev_remote_exists(github_repo):
            dev_url = f"git@github.com:odoo-dev/{github_repo}.git"
            git(bare_path, "remote", "add", "dev", dev_url)
            git(bare_path, "config", "--replace-all", "remote.dev.fetch", "+refs/heads/*:refs/remotes/dev/*")
            log_ok(f"Dev remote added: {dev_url}")

    log_ok(f"Repository ready: {bare_path.relative_to(ROOT_DIR)}")


def fetch_repo(repo: str, url: str | None = None) -> None:
    bare_path = CACHE_DIR / f"{repo}.git"
    if not bare_path.is_dir():
        log_info(f"Bare repo not found for '{repo}', setting it up automatically...")
        setup_bare_repo(repo, url=url)
    git(bare_path, "pack-refs", "--all", check=False)
    for remote in remotes(bare_path):
        log_info(f"Fetching {repo} ({remote})...")
        result = git(bare_path, "fetch", remote, "--prune", check=False)
        if result.returncode != 0:
            log_warn(f"Could not fetch {repo} from {remote}")


def find_ref(bare_path: Path, branch: str) -> str | None:
    """Return the full remote ref (e.g. 'origin/branch') if it exists, else None."""
    for remote in remotes(bare_path):
        result = git(bare_path, "rev-parse", "--verify", f"{remote}/{branch}", check=False, capture=True)
        if result.returncode == 0:
            return f"{remote}/{branch}"
    return None


def local_branch_exists(bare_path: Path, branch: str) -> bool:
    """Return True if a local branch exists in the bare repo."""
    result = git(bare_path, "branch", "--list", branch, check=False, capture=True)
    return result.returncode == 0 and result.stdout.decode().strip() != ""


def resolve_pr_branch(bare_path: Path, remote_name: str, pr_number: str) -> str:
    """Find the actual head branch name for a PR by SHA lookup.

    Returns the real branch name (e.g. '18.0-add-voip-telnyx-service-basm'),
    or falls back to 'pr-{number}'.
    """
    result = git(bare_path, "rev-parse", f"{remote_name}/pr/{pr_number}", check=False, capture=True)
    if result.returncode != 0:
        return f"pr-{pr_number}"
    sha = result.stdout.decode().strip()

    result = git(bare_path, "for-each-ref",
                 "--format=%(objectname) %(refname:short)",
                 "refs/remotes/", check=False, capture=True)
    if result.returncode != 0:
        return f"pr-{pr_number}"

    prefix = f"{remote_name}/"
    for line in result.stdout.decode().splitlines():
        parts = line.split(" ", 1)
        if len(parts) != 2:
            continue
        ref_sha, refname = parts
        if ref_sha == sha and "/pr/" not in refname and refname.startswith(prefix):
            return refname[len(prefix):]

    return f"pr-{pr_number}"


def find_or_add_remote(bare_path: Path, url: str, preferred_name: str) -> str:
    """Return the name of an existing remote with the given URL, or add one.

    If a remote with `url` already exists, return its name.
    Otherwise add `preferred_name` remote with a PR refspec and return it.
    """
    for remote_name in remotes(bare_path):
        result = git(bare_path, "remote", "get-url", remote_name, check=False, capture=True)
        if result.returncode == 0 and result.stdout.decode().strip() == url:
            return remote_name

    git(bare_path, "remote", "add", preferred_name, url)
    git(bare_path, "config", "--add", f"remote.{preferred_name}.fetch",
        f"+refs/pull/*/head:refs/remotes/{preferred_name}/pr/*")
    return preferred_name


def ensure_worktree(repo: str, branch: str) -> Path | None:
    bare_path = CACHE_DIR / f"{repo}.git"

    if not bare_path.is_dir():
        log_error(f"Bare repo not found: {bare_path}")
        return None

    branch_dir = branch_to_dir(branch)
    worktree_path = SRC_DIR / repo / branch_dir

    if worktree_path.is_dir():
        log_ok(f"Worktree exists: {worktree_path}")
        return worktree_path

    pr_spec = parse_pr(branch)
    if pr_spec:
        number = pr_spec["number"]
        if pr_spec["remote_url"]:
            # Fork PR: ensure remote exists, then targeted fetch
            org = pr_spec["github_org_repo"].split("/")[0]
            remote_name = find_or_add_remote(bare_path, pr_spec["remote_url"], org)
            log_info(f"Fetching PR #{number} from {remote_name}...")
            result = git(bare_path, "fetch", remote_name,
                         f"refs/pull/{number}/head:refs/remotes/{remote_name}/pr/{number}",
                         check=False)
            if result.returncode != 0:
                log_error(f"Failed to fetch PR #{number} from {remote_name}")
                return None
        else:
            remote_name = "origin"

        local_branch = resolve_pr_branch(bare_path, remote_name, number)
        pr_ref = f"{remote_name}/pr/{number}"

        if not local_branch_exists(bare_path, local_branch):
            git(bare_path, "branch", "--track", local_branch, pr_ref)

        worktree_path.parent.mkdir(parents=True, exist_ok=True)
        log_info(f"Creating PR worktree: {repo} PR#{number} -> {worktree_path} (branch: {local_branch})")
        result = git(bare_path, "worktree", "add", str(worktree_path), local_branch, check=False)
        if result.returncode != 0:
            log_error(f"Failed to create worktree for {repo} PR #{number}")
            return None
        log_ok(f"Created worktree: {worktree_path}")
        return worktree_path

    ref = find_ref(bare_path, branch)
    if ref is None:
        log_error(f"Branch/ref not found: {branch} in {repo}")
        log_info("Available branches:")
        git(bare_path, "branch", "-r", check=False)
        return None

    worktree_path.parent.mkdir(parents=True, exist_ok=True)
    log_info(f"Creating worktree: {repo}@{branch} -> {worktree_path} (from {ref})")

    if not local_branch_exists(bare_path, branch):
        git(bare_path, "branch", "--track", branch, ref)

    result = git(bare_path, "worktree", "add", str(worktree_path), branch, check=False)
    if result.returncode != 0:
        log_error(f"Failed to create worktree for {repo}@{branch}")
        return None

    log_ok(f"Created worktree: {worktree_path}")
    return worktree_path


def setup_js_tooling(worktree_paths: dict[str, Path], skip_repos: set[str] | None = None) -> None:
    community_path = worktree_paths.get("community")
    if community_path is None:
        return
    tooling_dir = community_path / "addons" / "web" / "tooling"
    if not tooling_dir.is_dir():
        return

    src_names = ["_eslintignore", "_eslintrc.json", "_jsconfig.json", "_package.json"]
    dst_names = [".eslintignore",  ".eslintrc.json",  "jsconfig.json",  "package.json"]

    for repo, repo_path in worktree_paths.items():
        if skip_repos and repo in skip_repos:
            continue
        if (repo_path / "jsconfig.json").exists():
            log_ok(f"JS tooling already present: {repo}")
        else:
            log_info(f"Setting up JS tooling for {repo}...")
            for src, dst in zip(src_names, dst_names):
                shutil.copy2(tooling_dir / src, repo_path / dst)
            if repo != "community":
                jsconfig = repo_path / "jsconfig.json"
                rel = os.path.relpath(community_path / "addons", repo_path)
                jsconfig.write_text(jsconfig.read_text().replace('"addons/', f'"{rel}/'))
            log_ok(f"JS tooling config installed: {repo_path.relative_to(ROOT_DIR)}")

        # npm install in community; symlink node_modules in others
        if repo == "community":
            if not (repo_path / "node_modules").exists():
                log_info("Running npm install in community (first time)...")
                subprocess.run(["npm", "install"], cwd=repo_path, check=False)
        else:
            nm = repo_path / "node_modules"
            if not nm.exists() and not nm.is_symlink():
                nm.symlink_to(community_path / "node_modules")
                log_ok(f"node_modules symlinked: {repo}")


def build_odoo_conf(root_dir: Path, addons_path: str, port: int, name: str, defaults: dict, odoorc_overrides: dict) -> Path:
    """Write .cache/envs/<name>/odoorc from merged defaults + overrides."""
    out = root_dir / ".cache" / "envs" / name / "odoorc"

    cfg = configparser.ConfigParser()
    cfg.add_section("options")

    # Apply global defaults then env-specific overrides (port handled separately)
    for key, value in defaults.items():
        if key != "port":
            cfg["options"][key] = str(value)
    for key, value in odoorc_overrides.items():
        if key != "port":
            cfg["options"][key] = str(value)

    cfg["options"]["addons_path"] = addons_path
    cfg["options"]["http_port"] = str(port)

    # Default db_name to env name if not explicitly set in defaults or overrides
    if "db_name" not in cfg["options"]:
        cfg["options"]["db_name"] = name

    # Default db_name to env name if not explicitly set in defaults or overrides
    if "dbfilter" not in cfg["options"]:
        cfg["options"]["dbfilter"] = f"^{cfg['options']['db_name']}$"

    out.parent.mkdir(parents=True, exist_ok=True)
    with open(out, "w") as f:
        cfg.write(f)
    return out


def discover_addons_paths(repo_path: Path) -> list[Path]:
    """Scan repo for Odoo module directories; return their parent dirs as addons paths."""
    SKIP = {"node_modules", ".git", "__pycache__", "setup"}
    addons_dirs: set[Path] = set()
    for manifest in repo_path.rglob("__manifest__.py"):
        if any(p in SKIP for p in manifest.parts):
            continue
        addons_dirs.add(manifest.parent.parent)
    return sorted(addons_dirs) if addons_dirs else [repo_path]


def build_paths(community_path: Path, extra_worktrees: dict[str, Path]) -> tuple[str, str]:
    python_path = str(community_path)
    addons_parts = [
        str(community_path / "addons"),
        str(community_path / "odoo" / "addons"),
    ]
    for repo_path in extra_worktrees.values():
        for p in reversed(discover_addons_paths(repo_path)):
            addons_parts.insert(0, str(p))
    return python_path, ",".join(addons_parts)


def generate_odools_config(
    env_name: str,
    worktree_paths: dict[str, Path],
    python_path: str,
    toml_data: dict | None = None,
) -> Path:
    """Write odools.toml for the Odoo LSP (gitignored, regenerated each run).
    When toml_data is provided, also generates [[config]] sections for all other
    environments whose community worktree exists on disk."""

    def _config_lines_for(name: str, paths: dict[str, Path], py_path: str) -> list[str]:
        comm = paths["community"]
        ent = paths.get("enterprise")
        ap: list[str] = []
        if ent:
            ap.append(str(ent))
        ap.append(str(comm / "addons"))
        ap.append(str(comm / "odoo" / "addons"))
        for repo, path in paths.items():
            if repo not in ("community", "enterprise"):
                for p in discover_addons_paths(path):
                    ap.append(str(p))
        section = ["[[config]]", f'name = "Odoo Dev — {name}"',
                   f'odoo_path = "{comm}"', "addons_paths = ["]
        for p in ap:
            section.append(f'    "{p}",')
        section.append("]")
        section.append(f'python_path = "{py_path}"')
        return section

    lines = ["# Auto-generated by odoo-env — do not edit manually",
             f"# Active environment: {env_name}", ""]
    lines.extend(_config_lines_for(env_name, worktree_paths, python_path))

    if toml_data is not None:
        for other_name in list_envs(toml_data):
            if other_name == env_name:
                continue
            other_paths = _worktree_paths_for_env(toml_data, other_name)
            if other_paths is None:
                continue
            lines.append("")
            lines.extend(_config_lines_for(other_name, other_paths, python_path))

    lines.append("")
    out = ROOT_DIR / "odools.toml"
    out.write_text("\n".join(lines))
    log_ok(f"Generated: {out.relative_to(ROOT_DIR)}")
    return out


def generate_vscode_workspace(
    name: str,
    worktree_paths: dict[str, Path],
    env: dict[str, str],
    odoo_rc_path: str,
) -> Path:
    """Generate a VS Code .code-workspace file for the environment."""
    env_dir = ROOT_DIR / ".cache" / "envs" / name
    out = env_dir / f"{name}.code-workspace"

    # Folders with paths relative to the workspace file location
    folders = []
    for repo, path in worktree_paths.items():
        rel = os.path.relpath(path, env_dir)
        folders.append({"name": repo, "path": rel})
    folders.append({"name": "odoo-env", "path": os.path.relpath(ROOT_DIR, env_dir)})

    venv_python = str(ROOT_DIR / ".venv" / "bin" / "python3")

    # Terminal env vars: all non-empty entries from env dict
    terminal_env = {k: v for k, v in env.items() if v}

    # Launch config env: same as activate, minus PATH (would clobber system PATH),
    # with workspace-relative substitutions where possible.
    launch_env = {k: v for k, v in env.items() if v and k != "PATH"}
    launch_env["PYTHONPATH"] = "${workspaceFolder:community}"
    launch_env["ODOO_PATH"] = "${workspaceFolder:community}"

    def _launch_config(label: str, args: list) -> dict:
        return {
            "name": label,
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder:community}",
            "program": "odoo-bin",
            "justMyCode": False,
            "pythonArgs": ["-Xfrozen_modules=off"],
            "args": args,
            "env": launch_env,
        }

    workspace = {
        "folders": folders,
        "settings": {
            "python.defaultInterpreterPath": venv_python,
            "search.useIgnoreFiles": False,
            "[python]": {
                "editor.defaultFormatter": "charliermarsh.ruff"
            },
            "files.exclude": {
                "**/__pycache__": True,
                "**/*.pyc": True,
                "**/node_modules": True,
            },
            "search.exclude": {
                "**/__pycache__": True,
                "**/*.pyc": True,
                "**/node_modules": True,
            },
            "Odoo.selectedProfile": f"Odoo Dev — {name}",
            "terminal.integrated.env.linux": terminal_env,
            "terminal.integrated.env.osx": terminal_env,
        },
        "launch": {
            "version": "0.2.0",
            "configurations": [
                _launch_config("Start Odoo", [
                    f"--config={odoo_rc_path}",
                    "--dev=all",
                ]),
                _launch_config("Start Debug Shell", [
                    "shell",
                    f"--config={odoo_rc_path}",
                    "--dev=all",
                ]),
                _launch_config("Run Console Tests", [
                    f"--config={odoo_rc_path}",
                    "--dev=all",
                    "--test-enable",
                    "--test-tags=${input:odooTestTags}",
                    "--stop-after-init",
                ]),
            ],
            "inputs": [
                {
                    "id": "odooTestTags",
                    "type": "promptString",
                    "description": "Choose a type of tests. Prefixes are: <none> for tags, / for modules, : for classes, . for methods.",
                }
            ],
        },
    }

    env_dir.mkdir(parents=True, exist_ok=True)
    out.write_text(json.dumps(workspace, indent=2))
    log_ok(f"Generated: {out.relative_to(ROOT_DIR)}")
    return out


def generate_zed_workspace(
    name: str,
    worktree_paths: dict[str, Path],
    env: dict[str, str],
) -> None:
    """Generate Zed workspace: symlinks to worktrees + .zed/settings.json."""
    env_dir = ROOT_DIR / ".cache" / "envs" / name
    env_dir.mkdir(parents=True, exist_ok=True)

    # Create relative symlinks for each worktree
    for repo, path in worktree_paths.items():
        link = env_dir / repo
        if link.exists() or link.is_symlink():
            link.unlink()
        rel = os.path.relpath(path, env_dir)
        link.symlink_to(rel)

    venv_python = str(ROOT_DIR / ".venv" / "bin" / "python3")

    settings = {
        "tab_size": 4,
        "lsp": {
            "basedpyright": {
                "settings": {
                    "python.pythonPath": venv_python,
                }
            }
        },
        "terminal": {
            "env": {
                "ODOO_ENV_NAME": env.get("ODOO_ENV_NAME", name),
                "ODOO_RC": env.get("ODOO_RC", ""),
                "PYTHONPATH": env.get("PYTHONPATH", ""),
                "ODOO_PATH": env.get("ODOO_PATH", ""),
            }
        },
        "file_scan_exclusions": [
            "**/__pycache__",
            "**/node_modules",
            "**/*.pyc",
        ],
    }

    zed_dir = env_dir / ".zed"
    zed_dir.mkdir(parents=True, exist_ok=True)
    zed_settings = zed_dir / "settings.json"
    zed_settings.write_text(json.dumps(settings, indent=2))
    log_ok(f"Generated: {zed_settings.relative_to(ROOT_DIR)}")


def generate_idea_project(
    name: str,
    worktree_paths: dict[str, Path],
    env: dict[str, str],
) -> None:
    """Generate a minimal JetBrains/PyCharm project in .cache/envs/{name}/.idea/."""
    env_dir = ROOT_DIR / ".cache" / "envs" / name
    idea_dir = env_dir / ".idea"
    idea_dir.mkdir(parents=True, exist_ok=True)

    iml_name = f"odoo-{name}.iml"

    # .idea/.name
    (idea_dir / ".name").write_text(f"odoo-{name}")

    # .idea/modules.xml
    (idea_dir / "modules.xml").write_text(
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<project version="4">\n'
        '  <component name="ProjectModuleManager">\n'
        '    <modules>\n'
        f'      <module fileurl="file://$PROJECT_DIR$/.idea/{iml_name}" filepath="$PROJECT_DIR$/.idea/{iml_name}" />\n'
        '    </modules>\n'
        '  </component>\n'
        '</project>\n'
    )

    # .idea/misc.xml
    (idea_dir / "misc.xml").write_text(
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<project version="4">\n'
        '  <component name="ProjectRootManager" version="2"'
        ' project-jdk-name="Python 3.12 (odoo-env)" project-jdk-type="Python SDK" />\n'
        '</project>\n'
    )

    # .idea/odoo-{name}.iml
    content_root_lines: list[str] = []
    for repo, path in worktree_paths.items():
        content_root_lines.append(f'    <content url="file://{path}">')
        content_root_lines.append(f'      <excludeFolder url="file://{path}/node_modules" />')
        content_root_lines.append(f'      <excludeFolder url="file://{path}/__pycache__" />')
        content_root_lines.append('    </content>')

    content_roots_str = "\n".join(content_root_lines)
    (idea_dir / iml_name).write_text(
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<module type="PYTHON_MODULE" version="4">\n'
        '  <component name="NewModuleRootManager" inherit-compiler-output="true">\n'
        '    <exclude-output />\n'
        f'{content_roots_str}\n'
        '    <orderEntry type="inheritedJdk" />\n'
        '    <orderEntry type="sourceFolder" forTests="false" />\n'
        '  </component>\n'
        '</module>\n'
    )

    log_ok(f"Generated: {idea_dir.relative_to(ROOT_DIR)}")


# --- odoo-env.toml management ---

def load_odoo_env_toml() -> dict:
    """Load odoo-env.toml from ROOT_DIR. If missing, copy from .example and exit."""
    toml_path = ROOT_DIR / "odoo-env.toml"
    example_path = ROOT_DIR / "odoo-env.toml.example"

    if not toml_path.exists():
        if example_path.exists():
            shutil.copy2(example_path, toml_path)
            log_ok("Created odoo-env.toml from example.")
            print("  Edit odoo-env.toml to configure your environments, then re-run.", file=sys.stderr)
        else:
            log_error("odoo-env.toml not found (and no odoo-env.toml.example to copy from).")
        sys.exit(1)

    with open(toml_path, "rb") as f:
        return tomllib.load(f)


def list_envs(toml_data: dict) -> list[str]:
    """Return sorted list of all env names except '_'."""
    return sorted(k for k in toml_data if k != "_")


def get_env(toml_data: dict, name: str) -> dict:
    """Return the env section dict. sys.exit(1) if not found or no effective branches."""
    if name == "_" or name not in toml_data:
        log_error(f"Environment '{name}' not found in odoo-env.toml")
        envs = list_envs(toml_data)
        if envs:
            print(f"  Available: {', '.join(envs)}", file=sys.stderr)
        sys.exit(1)

    env_section = toml_data[name]
    default_branches = toml_data.get("_", {}).get("branches", {})
    effective_branches = {**default_branches, **env_section.get("branches", {})}

    if not effective_branches:
        log_error(f"Environment '{name}' has no branches configured in odoo-env.toml")
        sys.exit(1)

    return env_section


def _repo_branches_for_env(toml_data: dict, env_name: str) -> dict[str, str]:
    """Return effective {repo: branch} dict for an environment."""
    env_section = toml_data.get(env_name, {})
    default_branches: dict[str, str] = toml_data.get("_", {}).get("branches", {})
    return {**default_branches, **env_section.get("branches", {})}


def _repo_urls_for_env(toml_data: dict, env_name: str) -> dict[str, str]:
    """Return effective {repo: url} dict for an environment (custom repos only)."""
    default_repos: dict[str, str] = toml_data.get("_", {}).get("repos", {})
    env_repos: dict[str, str] = toml_data.get(env_name, {}).get("repos", {})
    return {**default_repos, **env_repos}


def _worktree_paths_for_env(toml_data: dict, env_name: str) -> dict[str, Path] | None:
    """Return {repo: worktree_path} for env_name, checking only paths that exist on disk.
    Returns None if the community worktree is missing (env not set up yet)."""
    repo_branches = _repo_branches_for_env(toml_data, env_name)
    community_branch = repo_branches.get("community")
    if not community_branch:
        return None
    community_path = SRC_DIR / "community" / community_branch.replace("/", "-")
    if not community_path.is_dir():
        return None
    paths: dict[str, Path] = {"community": community_path}
    for repo, branch in repo_branches.items():
        if repo == "community":
            continue
        p = SRC_DIR / repo / branch.replace("/", "-")
        if p.is_dir():
            paths[repo] = p
    return paths


# --- Subcommands ---

def fetch_pr_title(org_repo: str, pr_number: str) -> str | None:
    """Fetch PR title using the gh CLI. Returns None if unavailable or on error."""
    if not shutil.which("gh"):
        return None
    result = subprocess.run(
        ["gh", "pr", "view", pr_number, "--repo", org_repo, "--json", "title", "-q", ".title"],
        capture_output=True,
        check=False,
    )
    if result.returncode == 0:
        return result.stdout.decode().strip() or None
    return None


def github_pr_url(bare_path: Path, pr_spec: dict) -> str | None:
    """Return the GitHub PR URL for a given PR spec dict."""
    number = pr_spec["number"]
    if pr_spec.get("github_org_repo"):
        return f"https://github.com/{pr_spec['github_org_repo']}/pull/{number}"

    # Origin PR: derive org/repo from the origin remote URL
    result = git(bare_path, "remote", "get-url", "origin", check=False, capture=True)
    if result.returncode != 0:
        return None
    url = result.stdout.decode().strip()
    m = re.match(r'git@github\.com:(.+?)(?:\.git)?$', url)
    if not m:
        m = re.match(r'https://github\.com/(.+?)(?:\.git)?$', url)
    if m:
        return f"https://github.com/{m.group(1)}/pull/{number}"
    return None


def _pr_annotation(bare_path: Path, pr_spec: dict) -> str:
    """Return a string with PR title (if fetchable) and URL for display in status."""
    url = github_pr_url(bare_path, pr_spec)
    if not url:
        return ""
    org_repo = pr_spec.get("github_org_repo")
    if not org_repo:
        # Origin PR: derive org/repo from remote URL
        result = git(bare_path, "remote", "get-url", "origin", check=False, capture=True)
        if result.returncode == 0:
            m = re.match(r'git@github\.com:(.+?)(?:\.git)?$', result.stdout.decode().strip())
            if m:
                org_repo = m.group(1)
    title = fetch_pr_title(org_repo, pr_spec["number"]) if org_repo else None
    if title:
        return f"  {BLUE}{hyperlink(title, url)}{NC}"
    return f"  {BLUE}{hyperlink(url, url)}{NC}"


def cmd_status(env_names: list[str], toml_data: dict) -> None:
    """Show git status (branch, ahead/behind, dirty) for each worktree."""
    for env_name in env_names:
        print(f"\n{BLUE}{env_name}{NC}")
        repo_branches = _repo_branches_for_env(toml_data, env_name)

        # Collect resolved PR branches for runbot bundle deduction
        resolved_pr_branches: dict[str, str] = {}

        for repo, branch in repo_branches.items():
            branch_dir = branch_to_dir(branch)
            worktree_path = SRC_DIR / repo / branch_dir
            pr_spec = parse_pr(branch)

            if not worktree_path.is_dir():
                annotation = ""
                if pr_spec:
                    bare_path = CACHE_DIR / f"{repo}.git"
                    annotation = _pr_annotation(bare_path, pr_spec)
                print(f"  {YELLOW}{repo}@{branch}{NC}  [not created]{annotation}")
                continue

            head = git_wt(worktree_path, "symbolic-ref", "--short", "HEAD", check=False, capture=True)
            current_branch = head.stdout.decode().strip() if head.returncode == 0 else "(detached)"

            ab = git_wt(worktree_path, "rev-list", "--left-right", "--count", "@{u}...HEAD",
                        check=False, capture=True)
            if ab.returncode == 0:
                parts = ab.stdout.decode().strip().split()
                ab_str = f"↓{parts[0]} ↑{parts[1]}"
            else:
                ab_str = "(no upstream)"

            dirty = git_wt(worktree_path, "status", "--porcelain", check=False, capture=True)
            dirty_str = f"  {RED}*dirty*{NC}" if dirty.stdout.decode().strip() else ""

            annotation = ""
            if pr_spec:
                bare_path = CACHE_DIR / f"{repo}.git"
                annotation = _pr_annotation(bare_path, pr_spec)
                # Resolve actual branch name for runbot bundle deduction
                resolved_pr_branches[branch] = current_branch

            print(f"  {GREEN}{repo}{NC}@{current_branch}  {ab_str}{dirty_str}{annotation}")

        # Show runbot bundle links
        bundles = deduce_runbot_bundles(repo_branches, resolved_pr_branches)
        for bundle, url in zip(bundles, runbot_bundle_urls(bundles)):
            print(f"  {BLUE}{hyperlink('runbot: ' + bundle, url)}{NC}")


def cmd_rebase(env_names: list[str], toml_data: dict) -> None:
    """Fetch bare repos and rebase tracking worktrees onto their upstream."""

    # Pass 1: collect worktree info and their upstream refs BEFORE fetching
    worktree_infos = []  # [(repo, branch, worktree_path, remote, upstream_branch)]

    for env_name in env_names:
        repo_branches = _repo_branches_for_env(toml_data, env_name)
        for repo, branch in repo_branches.items():
            branch_dir = branch_to_dir(branch)
            worktree_path = SRC_DIR / repo / branch_dir
            if not worktree_path.is_dir():
                log_warn(f"Worktree not found, skipping: {worktree_path}")
                continue

            head = git_wt(worktree_path, "symbolic-ref", "HEAD", check=False, capture=True)
            if head.returncode != 0:
                log_warn(f"Detached HEAD in {worktree_path}, skipping rebase")
                continue

            upstream = git_wt(worktree_path, "rev-parse", "--abbrev-ref", "@{u}", check=False, capture=True)
            if upstream.returncode != 0:
                log_warn(f"No upstream configured for {repo}@{branch}, skipping rebase")
                continue

            upstream_ref = upstream.stdout.decode().strip()  # e.g. "origin/master"
            remote, _, upstream_branch = upstream_ref.partition("/")
            worktree_infos.append((repo, branch, worktree_path, remote, upstream_branch))

    # Collect custom URLs across targeted envs
    repo_urls: dict[str, str] = {}
    for env_name in env_names:
        repo_urls.update(_repo_urls_for_env(toml_data, env_name))

    # Pass 2: fetch only the specific upstream branches needed (deduplicated)
    fetch_tasks: set[tuple[str, str, str]] = {
        (repo, remote, upstream_branch)
        for repo, _, _, remote, upstream_branch in worktree_infos
    }

    def fetch_specific(repo: str, remote: str, upstream_branch: str) -> None:
        bare_path = CACHE_DIR / f"{repo}.git"
        if not bare_path.is_dir():
            log_info(f"Bare repo not found for '{repo}', setting it up automatically...")
            setup_bare_repo(repo, url=repo_urls.get(repo))
        log_info(f"Fetching {repo} {upstream_branch} ({remote})...")
        result = git(bare_path, "fetch", remote, upstream_branch, check=False)
        if result.returncode != 0:
            log_warn(f"Could not fetch {repo}/{upstream_branch} from {remote}")

    with ThreadPoolExecutor() as executor:
        futures = {
            executor.submit(fetch_specific, repo, remote, upstream_branch): (repo, remote, upstream_branch)
            for repo, remote, upstream_branch in sorted(fetch_tasks)
        }
        for future in as_completed(futures):
            future.result()

    # Pass 3: rebase each worktree onto its upstream
    for repo, branch, worktree_path, remote, upstream_branch in worktree_infos:
        log_info(f"Rebasing {repo}@{branch} onto {remote}/{upstream_branch}...")
        result = git_wt(worktree_path, "rebase", "--autostash", "@{u}", check=False)
        if result.returncode != 0:
            log_warn(f"Rebase failed for {repo}@{branch} — resolve manually")
        else:
            log_ok(f"Rebased: {repo}@{branch}")


def cmd_remove(env_name: str, toml_data: dict) -> None:
    """Remove worktrees for the given environment.

    Local feature branches are deleted automatically if no other environment
    in odoo-env.toml uses the same branch for that repo.
    """
    repo_branches = _repo_branches_for_env(toml_data, env_name)

    # Build set of (repo, branch) pairs used by other envs
    other_branch_usage: set[tuple[str, str]] = set()
    for other_name in list_envs(toml_data):
        if other_name == env_name:
            continue
        for repo, branch in _repo_branches_for_env(toml_data, other_name).items():
            other_branch_usage.add((repo, branch))

    for repo, branch in repo_branches.items():
        branch_dir = branch_to_dir(branch)
        worktree_path = SRC_DIR / repo / branch_dir
        bare_path = CACHE_DIR / f"{repo}.git"

        if not worktree_path.is_dir():
            continue

        dirty = git_wt(worktree_path, "status", "--porcelain", check=False, capture=True)
        if dirty.stdout.decode().strip():
            log_error(f"Worktree is dirty, skipping: {worktree_path}")
            log_info("Commit or stash your changes before running remove.")
            continue

        log_info(f"Removing worktree: {worktree_path}")
        git(bare_path, "worktree", "remove", str(worktree_path), check=False)

        # Delete local feature branch if no other env uses it
        if stable_base(branch) is not None and (repo, branch) not in other_branch_usage:
            if local_branch_exists(bare_path, branch):
                log_info(f"Deleting local branch: {branch} in {repo}")
                git(bare_path, "branch", "-D", branch, check=False)

    # Prune stale worktree metadata from all bare repos
    for repo in repo_branches:
        bare_path = CACHE_DIR / f"{repo}.git"
        if bare_path.is_dir():
            git(bare_path, "worktree", "prune", check=False)


def cmd_list(toml_data: dict) -> None:
    envs = list_envs(toml_data)
    if envs:
        print("Configured environments:")
        for env_name in envs:
            env_section = toml_data[env_name]
            branches = env_section.get("branches", {})
            repos_info = ", ".join(f"{r}@{b}" for r, b in branches.items())
            print(f"  {GREEN}{env_name}{NC}  ({repos_info})")
    else:
        print("No environments configured in odoo-env.toml.")


def cmd_activate(name: str, toml_data: dict) -> None:
    current_env = os.environ.get("ODOO_ENV_NAME")
    if current_env:
        log_info(f"Switching from '{current_env}' to '{name}'...")
        log_info("Tip: use `oact <env>` to switch without nesting")

    env_section = get_env(toml_data, name)

    default_branches: dict[str, str] = toml_data.get("_", {}).get("branches", {})
    repo_branches: dict[str, str] = {**default_branches, **env_section.get("branches", {})}

    if "community" not in repo_branches:
        log_error("'community' branch is required but not found in branches for this environment.")
        sys.exit(1)

    repo_urls = _repo_urls_for_env(toml_data, name)

    defaults = toml_data.get("_", {}).get("odoorc", {})
    odoorc_overrides = env_section.get("odoorc", {})
    global_options = toml_data.get("_", {}).get("options", {})
    env_options = env_section.get("options", {})
    skip_js_tooling: set[str] = set(global_options.get("skip_js_tooling", [])) | set(env_options.get("skip_js_tooling", []))

    port = int(odoorc_overrides.get("port", defaults.get("port", 8069)))

    community_branch = repo_branches["community"]
    odoo_version = stable_base(community_branch) or community_branch

    log_info(f"Environment: {name}")
    for repo, branch in repo_branches.items():
        log_info(f"  {repo}: {branch}")

    SRC_DIR.mkdir(parents=True, exist_ok=True)

    # Fetch only repos whose worktree doesn't exist yet
    for repo, branch in repo_branches.items():
        branch_dir = branch_to_dir(branch)
        if not (SRC_DIR / repo / branch_dir).is_dir():
            fetch_repo(repo, url=repo_urls.get(repo))

    # Create worktrees (with stable-base fallback for non-community repos)
    worktree_paths: dict[str, Path] = {}
    for repo, branch in repo_branches.items():
        path = ensure_worktree(repo, branch)
        if path is None and repo != "community":
            fallback = stable_base(branch)
            if fallback:
                log_warn(f"Branch {branch!r} not found in {repo}, falling back to {fallback!r}...")
                fetch_repo(repo, url=repo_urls.get(repo))
                path = ensure_worktree(repo, fallback)
        if path is None:
            if repo == "community":
                log_error("community worktree is required")
                sys.exit(1)
            log_warn(f"Skipping {repo} (branch {branch!r} not found)")
            continue
        worktree_paths[repo] = path

    community_path = worktree_paths.get("community")
    if community_path is None:
        log_error("community worktree not available")
        sys.exit(1)

    setup_js_tooling(worktree_paths, skip_js_tooling)

    extra_worktrees = {repo: path for repo, path in worktree_paths.items() if repo != "community"}
    python_path, addons_path = build_paths(community_path, extra_worktrees)
    odoo_conf = build_odoo_conf(ROOT_DIR, addons_path, port, name, defaults, odoorc_overrides)

    generate_odools_config(name, worktree_paths, python_path, toml_data)

    enterprise_path = worktree_paths.get("enterprise")
    extra_paths = ":".join(
        str(p) for r, p in worktree_paths.items()
        if r not in ("community", "enterprise")
    )
    env = {
        "ODOO_ENV_NAME": name,
        "ODOO_VERSION": odoo_version,
        "ODOO_RC": str(odoo_conf),
        "PYTHONPATH": python_path,
        "ODOO_ADDONS_PATH": addons_path,
        "ODOO_PORT": str(port),
        "ODOO_PATH": str(community_path),
        "ODOO_ENTERPRISE_PATH": str(enterprise_path) if enterprise_path else "",
        "ODOO_EXTRA_PATHS": extra_paths,
        "PATH": str(community_path) + ":" + os.environ.get("PATH", ""),
    }

    env_dir = ROOT_DIR / ".cache" / "envs" / name
    vscode_ws = generate_vscode_workspace(name, worktree_paths, env, str(odoo_conf))
    generate_zed_workspace(name, worktree_paths, env)
    generate_idea_project(name, worktree_paths, env)

    print()
    log_ok("Environment ready!")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print(f"  Environment: {name}")
    print(f"  Port: {port}")
    print( "  Worktrees:")
    for repo, path in worktree_paths.items():
        print(f"    {path.relative_to(ROOT_DIR)}")
    ws_rel = vscode_ws.relative_to(ROOT_DIR)
    dir_rel = env_dir.relative_to(ROOT_DIR)
    print("  IDE workspaces:")
    print(f"    VS Code:   code {hyperlink(str(ws_rel), 'file://' + str(vscode_ws))}")
    print(f"    Zed:       zed  {dir_rel}")
    print(f"    JetBrains: pycharm {dir_rel}")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print()
    print("Useful commands:")
    print("  odoo-bin -c $ODOO_RC -d mydb")
    debinstall = community_path / "setup" / "debinstall.sh"
    if debinstall.is_file():
        print("  $ODOO_PATH/setup/debinstall.sh  # install Python deps via apt (recommended) (Debian/Ubuntu)")
    print("  pip install -r $ODOO_PATH/requirements.txt  # install Python deps through pip")
    print()

    os.environ.update(env)

    # Detect the actual running shell from the parent process (more reliable than $SHELL)
    try:
        shell = os.readlink(f"/proc/{os.getppid()}/exe")
    except OSError:
        shell = os.environ.get("SHELL", "/bin/sh")
    log_info("Launching subshell (exit to return)...")
    os.execv(shell, [shell, "-i"])


def env_completer(prefix, **kwargs):
    """Return env names from odoo-env.toml matching prefix (for argcomplete)."""
    toml_path = ROOT_DIR / "odoo-env.toml"
    if not toml_path.exists():
        return []
    try:
        with open(toml_path, "rb") as f:
            data = tomllib.load(f)
        return [k for k in data if k != "_" and k.startswith(prefix)]
    except Exception:
        return []


def main() -> None:
    SUBCOMMANDS = {"list", "activate", "status", "rebase", "remove"}

    # Shortcut: odoo-env <env> → odoo-env activate <env>
    if len(sys.argv) > 1 and sys.argv[1] not in SUBCOMMANDS and not sys.argv[1].startswith("-"):
        sys.argv.insert(1, "activate")

    parser = argparse.ArgumentParser(
        prog="odoo-env",
        description="Configure and launch an Odoo development environment",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command", metavar="<command>")

    subparsers.add_parser("list", help="List environments from odoo-env.toml")

    sp_activate = subparsers.add_parser("activate", help="Set up worktrees and launch shell")
    sp_activate.add_argument("env_name", help="Environment name").completer = env_completer

    subparsers.add_parser("status", help="Show git status of worktrees (current env, or all)")

    subparsers.add_parser("rebase", help="Fetch and rebase worktrees onto upstream (current env, or all)")

    sp_remove = subparsers.add_parser("remove", help="Remove worktrees for an environment")
    sp_remove.add_argument("env_name", help="Environment name").completer = env_completer

    if argcomplete:
        argcomplete.autocomplete(parser)

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    toml_data = load_odoo_env_toml()

    if args.command == "list":
        cmd_list(toml_data)
    elif args.command == "activate":
        cmd_activate(args.env_name, toml_data)
    elif args.command == "status":
        env_name = os.environ.get("ODOO_ENV_NAME")
        env_names = [env_name] if env_name else list_envs(toml_data)
        cmd_status(env_names, toml_data)
    elif args.command == "rebase":
        env_name = os.environ.get("ODOO_ENV_NAME")
        env_names = [env_name] if env_name else list_envs(toml_data)
        cmd_rebase(env_names, toml_data)
    elif args.command == "remove":
        cmd_remove(args.env_name, toml_data)


if __name__ == "__main__":
    main()
