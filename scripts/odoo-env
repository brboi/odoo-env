#!/usr/bin/env python3
"""odoo-env: Configure and launch an Odoo development environment.

Usage:
    odoo-env <env-name> [options]
    odoo-env --list

Environments are declared in odoo-env.toml at the repo root.
Copy odoo-env.toml.example to odoo-env.toml and customize.

Examples:
    odoo-env my-project              # Set up worktrees and launch shell
    odoo-env my-project --setup-only # Set up worktrees without launching shell
    odoo-env my-project --odoorc     # Regenerate odoorc only, no shell
    odoo-env --list                  # Show all environments from odoo-env.toml

Options: --port, --setup-only, --odoorc, --print-env, --list
"""

import argparse
import configparser
import os
import tomllib
import re
import shutil
import subprocess
import sys
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parent.parent
CACHE_DIR = ROOT_DIR / ".cache" / "git"
SRC_DIR = ROOT_DIR / "src"

# Maps local alias → GitHub repo name (only non-identity mappings)
REVERSE_ALIAS = {"community": "odoo"}

# ANSI colors
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
BLUE = "\033[0;34m"
NC = "\033[0m"


def log_info(msg: str) -> None:
    print(f"{BLUE}[INFO]{NC} {msg}", file=sys.stderr)


def log_ok(msg: str) -> None:
    print(f"{GREEN}[OK]{NC} {msg}", file=sys.stderr)


def log_warn(msg: str) -> None:
    print(f"{YELLOW}[WARN]{NC} {msg}", file=sys.stderr)


def log_error(msg: str) -> None:
    print(f"{RED}[ERROR]{NC} {msg}", file=sys.stderr)


def git(bare_path: Path, *args: str, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", f"--git-dir={bare_path}", *args],
        check=check,
        capture_output=capture,
    )


def stable_base(branch: str) -> str | None:
    """Return the stable base of a feature branch, or None if already stable.

    'master-parrot' -> 'master'
    '17.0-fix'      -> '17.0'
    'master'        -> None
    '18.0'          -> None
    """
    if re.match(r'^\d+\.\d+$', branch) or branch == "master":
        return None
    if branch.startswith("master-"):
        return "master"
    m = re.match(r'^(\d+\.\d+)-', branch)
    if m:
        return m.group(1)
    return None


def remotes(bare_path: Path) -> list[str]:
    """Return remotes ordered: origin first, then others alphabetically."""
    result = git(bare_path, "remote", check=False, capture=True)
    if result.returncode != 0:
        return []
    all_remotes = result.stdout.decode().split()
    return sorted(all_remotes, key=lambda r: (0 if r == "origin" else 1, r))


def dev_remote_exists(repo: str) -> bool:
    result = subprocess.run(
        ["git", "ls-remote", f"git@github.com:odoo-dev/{repo}.git"],
        capture_output=True, check=False,
    )
    return result.returncode == 0


def setup_bare_repo(alias: str) -> None:
    github_repo = REVERSE_ALIAS.get(alias, alias)
    repo_url = f"git@github.com:odoo/{github_repo}.git"
    bare_path = CACHE_DIR / f"{alias}.git"

    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    log_info(f"Cloning bare repository: {repo_url} -> {bare_path}")
    subprocess.run(["git", "clone", "--bare", repo_url, str(bare_path)], check=True)

    # Configure refspecs
    git(bare_path, "config", "--replace-all", "remote.origin.fetch", "+refs/heads/*:refs/remotes/origin/*")
    git(bare_path, "config", "--add", "remote.origin.fetch", "+refs/pull/*/head:refs/remotes/origin/pr/*")

    # Dev remote
    log_info(f"Checking for dev remote (github.com/odoo-dev/{github_repo})...")
    if dev_remote_exists(github_repo):
        dev_url = f"git@github.com:odoo-dev/{github_repo}.git"
        git(bare_path, "remote", "add", "dev", dev_url)
        git(bare_path, "config", "--replace-all", "remote.dev.fetch", "+refs/heads/*:refs/remotes/dev/*")
        log_ok(f"Dev remote added: {dev_url}")

    log_ok(f"Repository ready: {bare_path.relative_to(ROOT_DIR)}")


def fetch_repo(repo: str) -> None:
    bare_path = CACHE_DIR / f"{repo}.git"
    if not bare_path.is_dir():
        log_info(f"Bare repo not found for '{repo}', setting it up automatically...")
        setup_bare_repo(repo)
    for remote in remotes(bare_path):
        log_info(f"Fetching {repo} ({remote})...")
        result = git(bare_path, "fetch", remote, "--prune", check=False)
        if result.returncode != 0:
            log_warn(f"Could not fetch {repo} from {remote}")


def find_ref(bare_path: Path, branch: str) -> str | None:
    """Return the full remote ref (e.g. 'origin/branch') if it exists, else None."""
    for remote in remotes(bare_path):
        result = git(bare_path, "rev-parse", "--verify", f"{remote}/{branch}", check=False, capture=True)
        if result.returncode == 0:
            return f"{remote}/{branch}"
    return None


def ensure_worktree(repo: str, branch: str) -> Path | None:
    bare_path = CACHE_DIR / f"{repo}.git"

    if not bare_path.is_dir():
        log_error(f"Bare repo not found: {bare_path}")
        return None

    branch_dir = branch.replace("/", "-")
    worktree_path = SRC_DIR / repo / branch_dir

    if worktree_path.is_dir():
        log_ok(f"Worktree exists: {worktree_path}")
        return worktree_path

    ref = find_ref(bare_path, branch)
    if ref is None:
        log_error(f"Branch/ref not found: {branch} in {repo}")
        log_info("Available branches:")
        git(bare_path, "branch", "-r", check=False)
        return None

    worktree_path.parent.mkdir(parents=True, exist_ok=True)
    log_info(f"Creating worktree: {repo}@{branch} -> {worktree_path} (from {ref})")
    git(bare_path, "worktree", "add", str(worktree_path), ref, "--detach")
    log_ok(f"Created worktree: {worktree_path}")
    return worktree_path


def setup_js_tooling(worktree_paths: dict[str, Path]) -> None:
    community_path = worktree_paths.get("community")
    if community_path is None:
        return
    tooling_dir = community_path / "addons" / "web" / "tooling"
    if not tooling_dir.is_dir():
        return

    src_names = ["_eslintignore", "_eslintrc.json", "_jsconfig.json", "_package.json"]
    dst_names = [".eslintignore",  ".eslintrc.json",  "jsconfig.json",  "package.json"]

    for repo, repo_path in worktree_paths.items():
        if (repo_path / "jsconfig.json").exists():
            log_ok(f"JS tooling already present: {repo}")
        else:
            log_info(f"Setting up JS tooling for {repo}...")
            for src, dst in zip(src_names, dst_names):
                shutil.copy2(tooling_dir / src, repo_path / dst)
            if repo != "community":
                jsconfig = repo_path / "jsconfig.json"
                rel = os.path.relpath(community_path / "addons", repo_path)
                jsconfig.write_text(jsconfig.read_text().replace('"addons/', f'"{rel}/'))
            log_ok(f"JS tooling config installed: {repo_path.relative_to(ROOT_DIR)}")

        # npm install in community; symlink node_modules in others
        if repo == "community":
            if not (repo_path / "node_modules").exists():
                log_info("Running npm install in community (first time)...")
                subprocess.run(["npm", "install"], cwd=repo_path, check=False)
        else:
            nm = repo_path / "node_modules"
            if not nm.exists() and not nm.is_symlink():
                nm.symlink_to(community_path / "node_modules")
                log_ok(f"node_modules symlinked: {repo}")


def build_odoo_conf(root_dir: Path, addons_path: str, port: int, name: str, defaults: dict, odoorc_overrides: dict) -> Path:
    """Write .cache/envs/<name>/odoorc from merged defaults + overrides."""
    out = root_dir / ".cache" / "envs" / name / "odoorc"

    cfg = configparser.ConfigParser()
    cfg.add_section("options")

    # Apply global defaults then env-specific overrides (port handled separately)
    for key, value in defaults.items():
        if key != "port":
            cfg["options"][key] = str(value)
    for key, value in odoorc_overrides.items():
        if key != "port":
            cfg["options"][key] = str(value)

    cfg["options"]["addons_path"] = addons_path
    cfg["options"]["http_port"] = str(port)

    out.parent.mkdir(parents=True, exist_ok=True)
    with open(out, "w") as f:
        cfg.write(f)
    return out


def build_paths(community_path: Path, extra_worktrees: dict[str, Path]) -> tuple[str, str]:
    python_path = str(community_path)
    addons_parts = [
        str(community_path / "addons"),
        str(community_path / "odoo" / "addons"),
    ]
    for repo_path in extra_worktrees.values():
        addons_parts.insert(0, str(repo_path))
    return python_path, ",".join(addons_parts)


# --- odoo-env.toml management ---

def load_odoo_env_toml() -> dict:
    """Load odoo-env.toml from ROOT_DIR. If missing, copy from .example and exit."""
    toml_path = ROOT_DIR / "odoo-env.toml"
    example_path = ROOT_DIR / "odoo-env.toml.example"

    if not toml_path.exists():
        if example_path.exists():
            shutil.copy2(example_path, toml_path)
            log_ok("Created odoo-env.toml from example.")
            print("  Edit odoo-env.toml to configure your environments, then re-run.", file=sys.stderr)
        else:
            log_error("odoo-env.toml not found (and no odoo-env.toml.example to copy from).")
        sys.exit(1)

    with open(toml_path, "rb") as f:
        return tomllib.load(f)


def list_envs(toml_data: dict) -> list[str]:
    """Return sorted list of all env names except '_'."""
    return sorted(k for k in toml_data if k != "_")


def get_env(toml_data: dict, name: str) -> dict:
    """Return the env section dict. sys.exit(1) if not found or no effective branches."""
    if name == "_" or name not in toml_data:
        log_error(f"Environment '{name}' not found in odoo-env.toml")
        envs = list_envs(toml_data)
        if envs:
            print(f"  Available: {', '.join(envs)}", file=sys.stderr)
        sys.exit(1)

    env_section = toml_data[name]
    default_branches = toml_data.get("_", {}).get("branches", {})
    effective_branches = {**default_branches, **env_section.get("branches", {})}

    if not effective_branches:
        log_error(f"Environment '{name}' has no branches configured in odoo-env.toml")
        sys.exit(1)

    return env_section


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Configure and launch an Odoo development environment",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("env_name", nargs="?", help="Environment name (e.g. my-project, fix-invoice)")
    parser.add_argument("--list", action="store_true", help="List environments from odoo-env.toml")
    parser.add_argument("--port", type=int, help="Override HTTP port for this run")
    parser.add_argument("--setup-only", action="store_true", help="Create worktrees without launching shell")
    parser.add_argument("--odoorc", action="store_true", help="Regenerate .cache/envs/{name}/odoorc from current settings, no shell")
    parser.add_argument("--print-env", action="store_true", help="Print environment variables only")

    args = parser.parse_args()

    toml_data = load_odoo_env_toml()

    if args.list:
        envs = list_envs(toml_data)
        if envs:
            print("Configured environments:")
            for env_name in envs:
                env_section = toml_data[env_name]
                branches = env_section.get("branches", {})
                repos_info = ", ".join(f"{r}@{b}" for r, b in branches.items())
                print(f"  {GREEN}{env_name}{NC}  ({repos_info})")
        else:
            print("No environments configured in odoo-env.toml.")
        sys.exit(0)

    if not args.env_name:
        parser.print_help()
        sys.exit(1)

    name = args.env_name
    env_section = get_env(toml_data, name)

    default_branches: dict[str, str] = toml_data.get("_", {}).get("branches", {})
    repo_branches: dict[str, str] = {**default_branches, **env_section.get("branches", {})}

    if "community" not in repo_branches:
        log_error("'community' branch is required but not found in branches for this environment.")
        sys.exit(1)

    defaults = toml_data.get("_", {}).get("odoorc", {})
    odoorc_overrides = env_section.get("odoorc", {})

    # Port: env odoorc → global default → fallback 8069; CLI flag overrides all
    port = args.port if args.port is not None else int(odoorc_overrides.get("port", defaults.get("port", 8069)))

    community_branch = repo_branches["community"]
    odoo_version = stable_base(community_branch) or community_branch

    if args.odoorc:
        # Use existing worktrees only — no fetch, no create
        worktree_paths = {}
        for repo, branch in repo_branches.items():
            branch_dir = branch.replace("/", "-")
            path = SRC_DIR / repo / branch_dir
            if path.is_dir():
                worktree_paths[repo] = path

        community_path = worktree_paths.get("community")
        if community_path is None:
            log_error("Community worktree not found. Run without --odoorc to set up first.")
            sys.exit(1)

        extra_worktrees = {r: p for r, p in worktree_paths.items() if r != "community"}
        _, addons_path = build_paths(community_path, extra_worktrees)
        odoo_conf = build_odoo_conf(ROOT_DIR, addons_path, port, name, defaults, odoorc_overrides)
        log_ok(f"Generated: {odoo_conf.relative_to(ROOT_DIR)}")
        sys.exit(0)

    log_info(f"Environment: {name}")
    for repo, branch in repo_branches.items():
        log_info(f"  {repo}: {branch}")

    SRC_DIR.mkdir(parents=True, exist_ok=True)

    # Fetch only repos whose worktree doesn't exist yet
    for repo, branch in repo_branches.items():
        branch_dir = branch.replace("/", "-")
        if not (SRC_DIR / repo / branch_dir).is_dir():
            fetch_repo(repo)

    # Create worktrees (with stable-base fallback for non-community repos)
    worktree_paths: dict[str, Path] = {}
    for repo, branch in repo_branches.items():
        path = ensure_worktree(repo, branch)
        if path is None and repo != "community":
            fallback = stable_base(branch)
            if fallback:
                log_warn(f"Branch {branch!r} not found in {repo}, falling back to {fallback!r}...")
                fetch_repo(repo)
                path = ensure_worktree(repo, fallback)
        if path is None:
            if repo == "community":
                log_error("community worktree is required")
                sys.exit(1)
            log_warn(f"Skipping {repo} (branch {branch!r} not found)")
            continue
        worktree_paths[repo] = path

    community_path = worktree_paths.get("community")
    if community_path is None:
        log_error("community worktree not available")
        sys.exit(1)

    setup_js_tooling(worktree_paths)

    extra_worktrees = {repo: path for repo, path in worktree_paths.items() if repo != "community"}
    python_path, addons_path = build_paths(community_path, extra_worktrees)
    odoo_conf = build_odoo_conf(ROOT_DIR, addons_path, port, name, defaults, odoorc_overrides)

    enterprise_path = worktree_paths.get("enterprise")
    env = {
        "ODOO_VERSION": odoo_version,
        "ODOO_RC": str(odoo_conf),
        "PYTHONPATH": python_path + (":" + os.environ["PYTHONPATH"] if os.environ.get("PYTHONPATH") else ""),
        "ODOO_ADDONS_PATH": addons_path,
        "ODOO_PORT": str(port),
        "ODOO_PATH": str(community_path),
        "ODOO_ENTERPRISE_PATH": str(enterprise_path) if enterprise_path else "",
        "PATH": str(community_path) + ":" + os.environ.get("PATH", ""),
    }

    if args.print_env:
        for key, value in env.items():
            print(f'export {key}="{value}"')
        sys.exit(0)

    if args.setup_only:
        log_ok("Setup complete!")
        log_info(f"Community:  {community_path}")
        log_info(f"Enterprise: {enterprise_path}")
        debinstall = community_path / "setup" / "debinstall.sh"
        if debinstall.is_file():
            log_info(f"Run {debinstall}  # install Python deps via apt (Debian/Ubuntu)")
        else:
            log_info(f"Run: pip install -r {community_path}/requirements.txt")
        sys.exit(0)

    print()
    log_ok("Environment ready!")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print(f"  Environment: {name}")
    print(f"  Port: {port}")
    print( "  Worktrees:")
    for repo, path in worktree_paths.items():
        print(f"    {path.relative_to(ROOT_DIR)}")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print()
    print("Useful commands:")
    print("  odoo-bin -c $ODOO_RC -d mydb")
    debinstall = community_path / "setup" / "debinstall.sh"
    if debinstall.is_file():
        print(f"  $ODOO_PATH/setup/debinstall.sh  # install Python deps via apt (recommended) (Debian/Ubuntu)")
    print("  pip install -r $ODOO_PATH/requirements.txt  # install Python deps through pip")
    print()

    # Launch subshell — update process environment then exec
    os.environ.update(env)
    os.environ["PS1"] = f"(odoo:{name}) " + os.environ.get("PS1", "$ ")

    shell = os.environ.get("SHELL", "/bin/sh")
    log_info("Launching subshell (exit to return)...")
    os.execv(shell, [shell])


if __name__ == "__main__":
    main()
