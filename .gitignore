# Cache and local data
.cache/
.data/
.venv/

# Personal notes (except .gitkeep)
.notes/*
!.notes/.gitkeep

# Odoo sources (worktrees)
src/*
!src/.gitkeep

# Odoo LSP config (regenerated by odoo-env)
odools.toml

# Python
*.pyc
__pycache__/
*.egg-info/

# IDE
.idea/
.vscode/settings.json

# Claude Code local settings
.claude/

# Local configuration overrides
odoo-env.toml
mise.local.toml
